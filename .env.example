# Copia este archivo a .env y rellena tus llaves.
# OBLIGATORIAS: Kie.ai y ElevenLabs. OPCIONAL: Apify (solo si quieres fotos reales).

# --- Kie.ai — imágenes cartoon (Nano Banana) + música (Suno) ---
# Consigue tu llave en https://kie.ai (API Keys)
KIE_API_TOKEN=
KIE_BASE_URL=https://api.kie.ai/api/v1
KIE_MODEL=nano-banana-pro

# --- ElevenLabs — voz + efectos de sonido ---
# Consigue tu llave en https://elevenlabs.io (Profile → API Keys)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- Apify — fotos reales de internet (OPCIONAL) ---
# Solo si activaste "fotos reales". Cuenta gratis en https://apify.com
# OBLIGATORIA para el editor de reels (npm run edit:reel).
APIFY_TOKEN=
APIFY_IMAGES_ACTOR=automation-lab~google-images-scraper
APIFY_COUNTRY=mx
APIFY_LANGUAGE=es

# --- Editor de reels (npm run edit:reel) ---
# Solo si vas a editar reels que ya grabaste. Para hacer videos desde cero no hacen falta.
# OpenAI — transcripción con Whisper. Llave en https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Anthropic — análisis de temática y decisiones de edición. Llave en https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
