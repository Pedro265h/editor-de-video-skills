{
  "name": "video-vox",
  "version": "1.0.0",
  "private": true,
  "description": "Shorts explicativos animados estilo Vox (cartoon + slides + voz + música + SFX) con Remotion",
  "scripts": {
    "dev": "remotion studio",
    "studio": "remotion studio",
