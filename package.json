    "gen:voice": "node scripts/generate-voice.mjs",
    "gen:image": "node scripts/generate-image.mjs",
    "gen:music": "node scripts/generate-music.mjs",
    "gen:photos": "node scripts/fetch-photos.mjs",
    "transcribe": "node scripts/transcribe-video.mjs",
